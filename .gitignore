# Ignore environment variables
.env
backend/.env
backend/.env.*

# Ignore credentials
credentials.json
backend/credentials.json

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environment
venv/
.venv/

# Ignore build and distribution folders
dist/
build/
*.egg-info/

# Ignore logs
*.log
*.db
logs/
backend/app/logs/
backend/tools/logs/

# Ignore node modules (frontend)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/out/

# Ignore editor settings
.vscode/
.idea/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore temporary files
*.tmp
*.temp

# Ignore backup files
*.bak
*.old

# Ignore yarn/pnpm/npm lock files optionally
package-lock.json
yarn.lock
pnpm-lock.yaml